# Required for reading PCS evidence
# Path to PCS citations file (Parquet or CSV)
PCS_PATH=data/pcs_oa.parquet
# PCS format: parquet or csv
PCS_FORMAT=parquet

# OpenAlex (recommended)
OPENALEX_EMAIL=you@example.com
# Optional API key for higher quotas
# OPENALEX_API_KEY=

# Optional: control OpenAlex batching
# OPENALEX_MAX_IDS_PER_CALL=100
# OPENALEX_BATCH_SLEEP=0

# USPTO Assignment (optional token if required by your environment)
# USPTO_ASSIGN_BASE=https://assignment-api.uspto.gov
# USPTO_ASSIGN_TOKEN=

# PatentsView / PatentSearch API key for kind enrichment
# PV_API_KEY=
# PATENTSVIEW_API_KEY=

# Lens API (only needed if using lens_client module directly)
# LENS_API_TOKEN=

